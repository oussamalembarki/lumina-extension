{
  "manifest_version": 3,
  "name": "YouTube Study Mode",
  "version": "1.2",
  "action": { "default_popup": "popup.html" },
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}